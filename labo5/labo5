__global__ void findMaxReductionKernel(int* d_in, int* d_out, int n) {
    int tid = threadIdx.x;
    int i = blockIdx.x * blockDim.x + threadIdx.x;

    // Elke pass halveert het aantal actieve threads in een block
    for (unsigned int s = blockDim.x / 2; s > 0; s >>= 1) {
        if (tid < s && (i + s) < n) {
            if (d_in[i + s] > d_in[i]) {
                d_in[i] = d_in[i + s];
            }
        }
        __syncthreads();
    }

    // De winnaar van dit block schrijft naar de output array
    if (tid == 0) {
        d_out[blockIdx.x] = d_in[i];
    }
}

