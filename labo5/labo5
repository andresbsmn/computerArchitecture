__global__ void matrixMultiplicationGlobal(int *m1, int *m2, int *result, int rows, int columns) 
{
    int idx = threadIdx.x + blockIdx.x * blockDim.x;
    int size = rows * rows;

    if(idx < size)
    {
        int row = idx / rows;
        int col = idx % rows;
        int sum = 0;

        for(int k = 0; k < rows; k++)
        {
            sum += m1[row * rows + k] * m2[k * rows + col];
        }

        result[row * rows + col] = sum;
    }
}
__global__ void matrixSum(int *m1, int *m2, int *result, int rows)
{
    int idx = blockIdx.x * blockDim.x + threadIdx.x;
    int stride = blockDim.x * gridDim.x;
    int size = rows * rows;

    for(int i = idx; i < size; i += stride)
    {
        result[i] = m1[i] + m2[i];
    }
}


