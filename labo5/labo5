__global__ void findMaxReductionKernel(int* d_in, int* d_out, int n) {
    int tid = threadIdx.x;
    int i = blockIdx.x * blockDim.x + threadIdx.x;

    // Elke pass halveert het aantal actieve threads in een block
    for (unsigned int s = blockDim.x / 2; s > 0; s >>= 1) {
        if (tid < s && (i + s) < n) {
            if (d_in[i + s] > d_in[i]) {
                d_in[i] = d_in[i + s];
            }
        }
        __syncthreads();
    }

    // De winnaar van dit block schrijft naar de output array
    if (tid == 0) {
        d_out[blockIdx.x] = d_in[i];
    }
}

__global__ void findMinReductionKernel(int* d_in, int* d_out, int n) {
    int tid = threadIdx.x;
    int i = blockIdx.x * blockDim.x + threadIdx.x;

    // Elke pass halveert het aantal actieve threads in een block
    for (unsigned int s = blockDim.x / 2; s > 0; s >>= 1) {
        if (tid < s && (i + s) < n) {
            if (d_in[i + s] < d_in[i]) {
                d_in[i] = d_in[i + s];
            }
        }
        __syncthreads();
    }

    // De winnaar van dit block schrijft naar de output array
    if (tid == 0) {
        d_out[blockIdx.x] = d_in[i];
    }
}

__global__ void findMinAtomic(int* d_array, int* d_max, int n) {
    int idx = blockIdx.x * blockDim.x + threadIdx.x;
    if (idx < n) atomicMin(d_max, d_array[idx]);
}


__global__ void matrixMultiplicationGlobal(int *m1, int *m2, int *result, int rows, int columns) 
{
    int idx = threadIdx.x + blockIdx.x * blockDim.x;
    int size = rows * rows;

    if(idx < size)
    {
        int row = idx / rows;
        int col = idx % rows;
        int sum = 0;

        for(int k = 0; k < rows; k++)
        {
            sum += m1[row * rows + k] * m2[k * rows + col];
        }

        result[row * rows + col] = sum;
    }
}
__global__ void matrixSum(int *m1, int *m2, int *result, int rows)
{
    int idx = blockIdx.x * blockDim.x + threadIdx.x;
    int stride = blockDim.x * gridDim.x;
    int size = rows * rows;

    for(int i = idx; i < size; i += stride)
    {
        result[i] = m1[i] + m2[i];
    }
}

void printMatrix(const std::vector<int>& m, int rows, int collumns) {
    for(int r = 0; r < rows; r++) {
        for(int c = 0; c < collumns; c++) {
            std::cout << m[r * collumns + c] << " ";
        }
        std::cout << std::endl;
    }
}
void printResult(const std::vector<int>& m1, const std::vector<int>& m2, const std::vector<int>& result_matrix, int rows, int collumns){
        std::cout << std::string(20, '=') << std::endl<<std::endl;
        printMatrix(m1, rows, collumns);
        std::cout<<std::endl << " plus min maal, denk na en je zult het wel zien " << std::endl<<std::endl;
        printMatrix(m2, rows, collumns);
        std::cout << std::string(20, '-') << std::endl;
        printMatrix(result_matrix, rows, collumns);
        std::cout << std::string(20, '=') << std::endl<<std::endl;
}

std::vector<int> generateMatrix(int rows, int collumns) {
    std::vector<int> matrix(rows * collumns);
    for(int i = 0; i < rows * collumns; i++)
        matrix[i] = rand() % 100;  //
    return matrix;
}

int main() {
    std::vector<int> sizes = {3}; // Test size
    srand(42);

    int output;
    int threads1D = 256;

    int* d_matrix1;
    int* d_matrix2;
    int* d_result_matrix;
    int* d_out;

    cudaEvent_t start_cuda, stop_cuda;
    cudaEventCreate(&start_cuda);
    cudaEventCreate(&stop_cuda);

    std::cout << std::string(90, '-') << std::endl;

    for(int size : sizes){
        int rows = size;
        int columns = size;
        int blocks1D = (size * size + threads1D - 1) / threads1D;

        std::vector<int> m1 = generateMatrix(size, size);
        std::vector<int> m2 = generateMatrix(size, size);
        std::vector<int> result_matrix(size * size);

        std::cout << std::setw(10) << size<<std::endl;

        // Allocate device memory
        cudaMalloc(&d_matrix1, size * size * sizeof(int));
        cudaMalloc(&d_matrix2, size * size * sizeof(int));
        cudaMalloc(&d_result_matrix, size * size * sizeof(int));

        cudaMemcpy(d_matrix1, m1.data(), size * size * sizeof(int), cudaMemcpyHostToDevice);
        cudaMemcpy(d_matrix2, m2.data(), size * size * sizeof(int), cudaMemcpyHostToDevice);

        // Matrix sum
        matrixSum<<<blocks1D, threads1D>>>(d_matrix1, d_matrix2, d_result_matrix, size);
        cudaMemcpy(result_matrix.data(), d_result_matrix, size * size * sizeof(int), cudaMemcpyDeviceToHost);

        printResult(m1, m2, result_matrix, rows, columns);
        // multiplication
        matrixMultiplicationGlobal<<<blocks1D, threads1D>>>(d_matrix1, d_matrix2, d_result_matrix, size, size);
        cudaMemcpy(result_matrix.data(), d_result_matrix, size * size * sizeof(int), cudaMemcpyDeviceToHost);
        std::cout<<"maal doen..."<<std::endl;
        printResult(m1, m2, result_matrix, rows, columns);
        // Allocate temporary memory for reduction
        int max_size = size * size;
        cudaMalloc(&d_out, ((max_size + threads1D - 1) / threads1D) * sizeof(int));
        int* d_in = d_matrix1; // Use original matrix for reduction
        int* d_tmp = d_out;

        // Max reduction
        int current_n = max_size;
        while(current_n > 1){
            int blocksPerGrid = (current_n + threads1D - 1) / threads1D;
            findMaxReductionKernel<<<blocksPerGrid, threads1D>>>(d_in, d_tmp, current_n);
            cudaDeviceSynchronize();

            // Swap pointers
            int* temp = d_in;
            d_in = d_tmp;
            d_tmp = temp;

            current_n = blocksPerGrid;
        }
        cudaMemcpy(&output, d_in, sizeof(int), cudaMemcpyDeviceToHost);
        std::cout << "Max value: " << output << std::endl;

        // Min reduction (same idea)
        current_n = max_size;
        d_in = d_matrix1;
        d_tmp = d_out;
        while(current_n > 1){
            int blocksPerGrid = (current_n + threads1D - 1) / threads1D;
            findMinReductionKernel<<<blocksPerGrid, threads1D>>>(d_in, d_tmp, current_n);
            cudaDeviceSynchronize();

            int* temp = d_in;
            d_in = d_tmp;
            d_tmp = temp;

            current_n = blocksPerGrid;
        }
        cudaMemcpy(&output, d_in, sizeof(int), cudaMemcpyDeviceToHost);
        std::cout << "Min value: " << output << std::endl;

        // Free GPU memory
        cudaFree(d_matrix1);
        cudaFree(d_matrix2);
        cudaFree(d_result_matrix);
        cudaFree(d_out);
    }

    return 0;
}
