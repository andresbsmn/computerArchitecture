void printMatrix(const std::vector<int>& m, int rows, int cols) {
    for(int r = 0; r < rows; r++) {
        for(int c = 0; c < cols; c++) {
            std::cout << m[r * cols + c] << " ";
        }
        std::cout << std::endl;
    }
}
void matrixTransposeCPU(const std::vector<int>& matrix,
                   std::vector<int>& result, int rows, int columns) {
    int R = rows;
    int K = columns;
    int index, invIndex;
    for(int row = 0; row<R;row++){
        for(int column = 0; column < K; column++ ){
            index= row * R + column;
            invIndex = column * K + row;               
            result[invIndex] = matrix[index];
        }
    }
}
