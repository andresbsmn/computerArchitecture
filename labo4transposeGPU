// CUDA kernel to rev 1 arrays
__global__ void matrixCopyGPU(int *a, int *c, int size) { 
    int idx = threadIdx.x + blockIdx.x * blockDim.x;
    if(idx < size)
        c[idx] = a[idx];
}
__global__ void matrixTransposeGPU(int *a, int *c, int rows, int columns) 
{
    int idx = threadIdx.x + blockIdx.x * blockDim.x;
    int size = rows * columns;
    if(idx < size)
    {
        int row = idx / columns; //gehele deling
        int col = idx % columns; //rest v/d vorige deling (start bij nul, dus ok)
        int transposedIndex = col * rows + row;

        c[transposedIndex] = a[idx];
    }
}


void matrixCopyCPU(const std::vector<int>& matrix,
                   std::vector<int>& result) {
    result = matrix;
}
void printMatrix(const std::vector<int>& m, int rows, int cols) {
    for(int r = 0; r < rows; r++) {
        for(int c = 0; c < cols; c++) {
            std::cout << m[r * cols + c] << " ";
        }
        std::cout << std::endl;
    }
}
void matrixTransposeCPU(const std::vector<int>& matrix,
                        std::vector<int>& result, int rows, int columns) {
    for (int row = 0; row < rows; row++) {
        for (int col = 0; col < columns; col++) {
            int index        = row * columns + col;   // source: row-major in original
            int invIndex     = col * rows    + row;   // dest:   row-major in transposed
            result[invIndex] = matrix[index];
        }
    }
}
